# Exemplo de variáveis de ambiente do Sistema de Oficina Mecânica
# Copie para .env:  cp .env.example .env
# (os valores abaixo já são os padrões usados pelo projeto)

# aplicação
APP_PORT=8080

# postgresq;
POSTGRES_DB=oficina
POSTGRES_USER=oficina
POSTGRES_PASSWORD=oficina
POSTGRES_HOST_PORT=5432

# grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# prometheus 
PROMETHEUS_PORT=9090
